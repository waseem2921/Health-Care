# Django
SECRET_KEY=replace-with-strong-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# NeonDB PostgreSQL (optional - if offline or unavailable, app automatically uses local SQLite)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Always allow fallback to local SQLite for seamless offline operation
ALLOW_SQLITE_FALLBACK=True
USE_LOCAL_DB=False
LOCAL_DB_PATH=local_offline.db

# Cloudinary (optional - if offline, app uses local media storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
REQUIRE_CLOUDINARY=False
