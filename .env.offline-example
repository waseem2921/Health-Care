# ════════════════════════════════════════════════════════════════════════════════
# OFFLINE-FIRST HEALTHCARE AI SYSTEM - ENVIRONMENT CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════
#
# This file demonstrates all available configuration options for the offline-first
# Django healthcare system. Copy to .env and customize for your environment.
#
# IMPORTANT: 
# - Database switching happens automatically based on connectivity
# - Storage switching happens automatically based on availability
# - No manual intervention needed for normal operation
#

# ────────────────────────────────────────────────────────────────────────────────
# Django Core Configuration
# ────────────────────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-your-secret-key-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ────────────────────────────────────────────────────────────────────────────────
# Cloud Database Configuration (NeonDB / PostgreSQL)
# ────────────────────────────────────────────────────────────────────────────────
# System will automatically switch to SQLite if this is unavailable
DATABASE_URL=postgresql://user:password@neon.example.com:5432/healthcare_db

# Require cloud database (fail instead of falling back to SQLite)
# Keep as False to enable offline resilience
REQUIRE_POSTGRES=False

# ────────────────────────────────────────────────────────────────────────────────
# Cloudinary Configuration (Cloud Storage)
# ────────────────────────────────────────────────────────────────────────────────
# System will automatically use local storage if Cloudinary is unavailable
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Require Cloudinary for media storage (fail instead of using local storage)
# Keep as False to enable offline resilience
REQUIRE_CLOUDINARY=False

# ────────────────────────────────────────────────────────────────────────────────
# Offline-First Configuration
# ────────────────────────────────────────────────────────────────────────────────

# FORCE_OFFLINE: Set to True to always use offline mode (for testing/restricted networks)
# Default: False (automatic detection based on connectivity)
FORCE_OFFLINE=False

# USE_LOCAL_DB: Set to True to always use local SQLite instead of PostgreSQL
# Useful for testing offline functionality
# Default: False (uses PostgreSQL if available)
USE_LOCAL_DB=False

# USE_LOCAL_STORAGE: Set to True to always use local storage instead of Cloudinary
# Useful for testing local storage functionality
# Default: False (uses Cloudinary if available)
USE_LOCAL_STORAGE=False

# ALLOW_SQLITE_FALLBACK: Allow automatic fallback to SQLite if PostgreSQL fails
# Default: True (highly recommended)
ALLOW_SQLITE_FALLBACK=True

# LOCAL_DB_PATH: Path to local SQLite database for offline mode
# Default: local_offline.db (in project root)
LOCAL_DB_PATH=local_offline.db

# CONNECTIVITY_CACHE_DURATION: How long to cache connectivity check results (seconds)
# Prevents excessive network calls
# Default: 30 seconds
CONNECTIVITY_CACHE_DURATION=30

# ────────────────────────────────────────────────────────────────────────────────
# Logging Configuration
# ────────────────────────────────────────────────────────────────────────────────

# LOG_LEVEL: Logging verbosity level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# Enable detailed offline operation logging
# Logs to logs/offline_operations.log
OFFLINE_LOG_ENABLED=True

# Enable sync operation logging
# Logs to logs/sync_operations.log
SYNC_LOG_ENABLED=True

# ────────────────────────────────────────────────────────────────────────────────
# Google OAuth Configuration (Optional)
# ────────────────────────────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# REDIRECT_URIS=http://localhost:8000/oauth/callback,https://yourdomain.com/oauth/callback

# ────────────────────────────────────────────────────────────────────────────────
# Startup Behavior Configuration
# ────────────────────────────────────────────────────────────────────────────────

# STARTUP_DB_TIMEOUT: Seconds to wait for database connection at startup
# If timeout exceeded, automatically switches to SQLite
# Default: 3 seconds
STARTUP_DB_TIMEOUT=3

# STARTUP_STORAGE_TIMEOUT: Seconds to wait for storage connection at startup
# If timeout exceeded, automatically switches to local storage
# Default: 3 seconds
STARTUP_STORAGE_TIMEOUT=3

# ════════════════════════════════════════════════════════════════════════════════
# SECTION: OFFLINE OPERATION EXAMPLES
# ════════════════════════════════════════════════════════════════════════════════

# Example 1: Restricted Network Environment (No Cloud Access)
# ─────────────────────────────────────────────────────────
# Uncomment these to test/deploy in offline environments:
# FORCE_OFFLINE=True
# USE_LOCAL_DB=True
# USE_LOCAL_STORAGE=True
#
# Result: System runs completely offline with SQLite + Local Storage
#         No cloud connectivity required
#

# Example 2: Testing Offline Mode
# ─────────────────────────────────────────────────────────
# Uncomment to force offline mode while keeping cloud config:
# FORCE_OFFLINE=True
#
# Result: Simulates offline environment while credentials are configured
#         Useful for testing offline scenarios in development
#

# Example 3: Cloud-First with Fallback
# ─────────────────────────────────────────────────────────
# Keep all settings default:
# FORCE_OFFLINE=False
# USE_LOCAL_DB=False
# USE_LOCAL_STORAGE=False
# ALLOW_SQLITE_FALLBACK=True
#
# Result: Uses cloud services normally
#         Automatically switches to offline if cloud unavailable
#         Recommended for production
#

# ════════════════════════════════════════════════════════════════════════════════
# MIGRATION & SYNC COMMANDS
# ════════════════════════════════════════════════════════════════════════════════

# After setting configuration, run these commands:
#
# 1. Create/update database (applies offline-first migrations):
#    $ python manage.py migrate
#
# 2. Test offline mode:
#    $ export FORCE_OFFLINE=True
#    $ python manage.py runserver
#
# 3. Sync unsynced records to cloud (when online):
#    $ python manage.py sync_to_cloud
#
# 4. Check sync status (dry-run):
#    $ python manage.py sync_to_cloud --dry-run
#
# 5. Sync specific model only:
#    $ python manage.py sync_to_cloud --model=Patient
#

# ════════════════════════════════════════════════════════════════════════════════
# TROUBLESHOOTING
# ════════════════════════════════════════════════════════════════════════════════

# If database is not switching to offline mode on connection failure:
# 1. Check ALLOW_SQLITE_FALLBACK is True
# 2. Check LOCAL_DB_PATH is writable
# 3. Check logs/offline_operations.log for errors
# 4. Try: export USE_LOCAL_DB=True (manual override)

# If storage is not switching to local files on Cloudinary failure:
# 1. Ensure MEDIA_ROOT directory exists (media/)
# 2. Check directory is writable by Django process
# 3. Try: export USE_LOCAL_STORAGE=True (manual override)

# If sync is not working:
# 1. Run: python manage.py migrate (ensure is_synced field exists)
# 2. Check: python manage.py shell
#    >>> from core.models import Patient
#    >>> Patient.objects.filter(is_synced=False).count()
# 3. Run: python manage.py sync_to_cloud --dry-run (preview changes)
# 4. Run: python manage.py sync_to_cloud --force (force sync)
